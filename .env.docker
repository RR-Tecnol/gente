APP_NAME="GENTE"
APP_DESCRICAO="Gestão de Pessoas"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

AMBIENTE=desenv

LOG_CHANNEL=stack
LOG_LEVEL=debug

# SQL Server no container Docker
DB_CONNECTION=sqlsrv
DB_HOST=sqlserver
DB_PORT=1433
DB_DATABASE=gente
DB_USERNAME=sa
DB_PASSWORD=Gente@2024

BROADCAST_DRIVER=log
CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@gente.local"
MAIL_FROM_NAME="GENTE"
