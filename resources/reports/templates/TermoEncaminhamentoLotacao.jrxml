				</reportElement>
				<textElement textAlignment="Center">
					<font size="12" isBold="false"/>
				</textElement>
				<text><![CDATA[Atenciosamente,]]></text>
			</staticText>
			<textField>
				<reportElement x="10" y="322" width="534" height="18" uuid="0c21e7ef-e92d-4334-8884-fd7ce6335c13"/>
				<textElement markup="html">
					<font size="12" isBold="false"/>
				</textElement>
				<textFieldExpression><![CDATA["<b>CPF:</b> " + ($F{CPF} != null ? $F{CPF} : "NÃO INFORMADO")]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="10" y="339" width="534" height="18" uuid="3d4538a9-102e-4aa8-bde5-6dc20d5049fd"/>
				<textElement markup="html">
					<font size="12" isBold="false"/>
				</textElement>
				<textFieldExpression><![CDATA["<b>ENDEREÇO:</b> " + 
(
  $F{PESSOA_ENDERECO} != null && $F{BAIRRO_NOME} != null && $F{CIDADE_NOME} != null
    ? $F{PESSOA_ENDERECO} + 
      ($F{PESSOA_COMPLEMENTO} != null ? ", " + $F{PESSOA_COMPLEMENTO} : "") + 
